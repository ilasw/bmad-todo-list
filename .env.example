# Database connection (PostgreSQL)
# If you change POSTGRES_HOST_PORT, update the port in DATABASE_URL to match.
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://todo:todo@localhost:5432/todo_list
# Separate DB for API tests — prevents `pnpm test` from wiping dev todos
TEST_DATABASE_URL=postgresql://todo:todo@localhost:5432/todo_list_test

# Frontend API base URL (used by Vite at build/dev time)
VITE_API_URL=http://localhost:3000

# Runtime environment
NODE_ENV=development

# API server port
PORT=3000
